{
  "model": {
    "image_size": 256,
    "num_classes": 8,
    "max_prompt_classes": 6,
    "backbone_widths": [48, 96, 192, 384],
    "neck_channels": 192,
    "prompt_dim": 256,
    "reg_max": 16,
    "num_attention_heads": 8,
    "prompt_crop_size": 128,
    "label_dropout": 0.4,
    "logit_scale_init": 1.5,
    "max_logit_scale": 2.5,
    "detail_score_weight": 0.5
  },
  "context_painter": {
    "enabled": true,
    "scale": "p4",
    "dim": 256,
    "depth": 6,
    "num_heads": 8,
    "feature_ensemble_start": 2,
    "recon_weight": 0.5,
    "prior_weight": 1.0,
    "prior_warmup_ratio": 0.1,
    "color_min_distance": 0.45,
    "soft_box_sigma": 0.35,
    "color_temperature": 10.0
  },
  "data": {
    "train_list": "./toy_data/train.txt",
    "val_list": "./toy_data/val.txt",
    "train_labels_dir": "./toy_data/labels/train",
    "val_labels_dir": "./toy_data/labels/val",
    "class_names_path": "./toy_data/classes.txt",
    "min_prompt_classes": 1,
    "max_prompt_classes": 3,
    "max_prompt_instances_per_class": 2,
    "max_prompt_images": 4,
    "negative_ratio": 0.35,
    "hard_negative_ratio": 0.35,
    "episodes_per_epoch": 1000,
    "val_episodes": 200,
    "num_workers": 2
  },
  "train": {
    "output_dir": "./outputs/toy_run",
    "batch_size": 8,
    "epochs": 20,
    "lr": 0.0003,
    "weight_decay": 0.0001,
    "warmup_epochs": 2,
    "device": "cuda",
    "seed": 42,
    "mixed_precision": true,
    "grad_clip": 5.0,
    "conf_threshold": 0.15,
    "nms_iou_threshold": 0.5,
    "pre_nms_topk": 256,
    "one2one_topk": 300,
    "one2one_peak_kernel": 3,
    "oversize_box_threshold": 0.85,
    "oversize_box_gamma": 20.0,
    "max_det": 100,
    "eval_interval": 1,
    "save_interval": 1,
    "resume": ""
  },
  "loss": {
    "tal_topk": 9,
    "tal_alpha": 1.0,
    "tal_beta": 6.0,
    "center_sampling_radius": 0.5,
    "one2one_center_sampling_radius": 0.75,
    "one2one_candidate_topk": 8,
    "one2one_duplicate_radius": 1.25,
    "non_target_center_sampling_radius": 0.75,
    "objectness_weight": 1.0,
    "targetness_weight": 1.0,
    "null_weight": 0.5,
    "match_weight": 1.0,
    "iou_weight": 7.5,
    "dfl_weight": 1.5,
    "duplicate_weight": 0.5,
    "non_target_weight": 1.0,
    "confusable_non_target_weight": 2.0,
    "non_target_logit_margin": 0.0,
    "oversize_box_weight": 0.5,
    "oversize_box_threshold": 0.85,
    "oversize_box_topk": 16,
    "contrast_weight": 0.25,
    "focal_alpha": 0.25,
    "focal_gamma": 2.0,
    "classification_margin": 0.2,
    "one2many_weight": 1.0,
    "one2one_weight": 1.5
  }
}
